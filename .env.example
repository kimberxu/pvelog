# Database connection URL
DB_URL=sqlite+aiosqlite:///./pve_aiops.db

# Pre-Shared Key (PSK) secret for agent authentication
PSK_SECRET=YOUR_SECURE_PSK_HERE

# LLM Config
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=YOUR_API_KEY_HERE
LLM_MODEL=deepseek-v3.2

# SMTP Config (for alert emails)
SMTP_SERVER=smtp.example.com
SMTP_PORT=465
SMTP_USERNAME=your_email@example.com
SMTP_PASSWORD=your_email_password
EMAIL_FROM=your_email@example.com
ALERT_EMAIL_TO=admin@example.com

# Interval Settings (in seconds)
# Agent log collection & pushing interval (default: 300 seconds / 5 minutes)
PVE_COLLECT_INTERVAL_SEC=300

# Controller periodic inspection & analysis interval (default: 3600 seconds / 1 hour)
INSPECT_INTERVAL_SEC=3600

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
# Set to DEBUG to inspect detailed LLM request and agent execution trace logs.
LOG_LEVEL=INFO

